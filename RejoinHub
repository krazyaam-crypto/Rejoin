-- TIMER
local startTime = os.time()
local timerLabel = Tab:CreateLabel("Time: 00:00:00")

task.spawn(function()
	while true do
		task.wait(1)
		local t = os.time() - startTime
		local h = math.floor(t/3600)
		local m = math.floor((t%3600)/60)
		local s = t%60
		
		timerLabel:Set("Time: "..string.format("%02d:%02d:%02d",h,m,s))
	end
end)

-- LOG
local logs = {}
local logBox = Tab:CreateParagraph({Title="Log", Content="..."})

local function updateLog()
	logBox:Set({
		Title = "Log",
		Content = (#logs > 0 and table.concat(logs,"\n") or "Chưa có dữ liệu")
	})
end

local function addLog(text)
	local time = os.date("%H:%M:%S")
	table.insert(logs, "["..time.."] "..text)
	updateLog()
end

-- REJOIN
local function rejoin()
	task.wait(2)
	TeleportService:Teleport(game.PlaceId, player)
end

game:GetService("CoreGui").RobloxPromptGui.promptOverlay.ChildAdded:Connect(function(child)
	if child.Name == "ErrorPrompt" then
		
		local msg = ""
		pcall(function()
			msg = child.MessageArea.ErrorFrame.ErrorMessage.Text
		end)

		msg = string.lower(msg or "")

		if string.find(msg,"full") then return end
		if string.find(msg,"teleport") then return end

		if string.find(msg,"kick")
		or string.find(msg,"disconnect")
		or string.find(msg,"connection")
		or string.find(msg,"error") then
			
			addLog("Kick → Rejoin")
			rejoin()
		end
	end
end)

-- HOP SERVER (FIX)
local function hopLow()
	local placeId = game.PlaceId
	
	local req = game:HttpGet(
		"https://games.roblox.com/v1/games/"..2753915549.."/servers/Public?sortOrder=Asc&limit=100"
	)
	
	local data = HttpService:JSONDecode(req)
	local servers = {}

	for _,v in pairs(data.data) do
		if v.playing < v.maxPlayers then
			table.insert(servers, v.id)
		end
	end

	if #servers > 0 then
		local id = servers[math.random(1,#servers)]
		addLog("Hop server")
		TeleportService:TeleportToPlaceInstance(placeId, id, player)
	else
		addLog("Không có server")
	end
end

